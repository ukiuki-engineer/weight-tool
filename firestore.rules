rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get(
               "isAdmin",
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("admin", false)
             ) == true;
    }

    function validUserSettings() {
      return request.resource.data.name is string
             && request.resource.data.name.size() <= 32
             && request.resource.data.memo is string
             && request.resource.data.memo.size() <= 80
             && request.resource.data.defaultView in ["graph", "summary", "entry", "target"];
    }

    match /users/{userId} {
      allow get: if signedIn()
                 && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if signedIn()
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly(["name", "memo", "defaultView", "isAdmin"])
                    && request.resource.data.isAdmin == false
                    && validUserSettings();
      allow update: if signedIn()
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["name", "memo", "defaultView"])
                    && validUserSettings();
      allow delete: if false;

      match /weights/{date} {
        allow read, write: if signedIn()
                           && (request.auth.uid == userId || isAdmin());
      }

      match /targets/{date} {
        allow read, write: if signedIn()
                           && (request.auth.uid == userId || isAdmin());
      }
    }
  }
}
